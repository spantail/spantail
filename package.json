{
	"name": "spantail-monorepo",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@11.9.0",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"predev": "tsx scripts/ensure-dev-vars.ts",
		"dev": "pnpm --filter web dev",
		"test": "vitest run",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "pnpm -r run typecheck",
		"knip": "knip",
		"depcruise": "depcruise packages apps/web/src",
		"quality": "pnpm knip && pnpm depcruise",
		"db:generate": "pnpm --filter @spantail/db run generate",
		"db:migrate:local": "pnpm --filter web exec wrangler d1 migrations apply DB --local",
		"db:migrate:remote": "pnpm --filter web exec wrangler d1 migrations apply DB --remote",
		"db:drop": "tsx packages/db/seed/drop.ts",
		"db:seed": "tsx packages/db/seed/seed.ts",
		"db:reset": "pnpm db:drop && pnpm db:migrate:local",
		"generate-import": "tsx packages/db/seed/generate-import.ts",
		"deploy": "pnpm --filter web run deploy",
		"docs:dev": "pnpm --filter docs dev",
		"docs:build": "pnpm --filter docs build",
		"docs:preview": "pnpm --filter docs preview",
		"docs:typecheck": "pnpm --filter docs typecheck",
		"docs:deploy": "pnpm --filter docs run deploy"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"dependency-cruiser": "^18.0.0",
		"knip": "^6.25.0",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	}
}
