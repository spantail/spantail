{
	// compilerOptions here exist only for tooling that reads the root tsconfig
	// (shadcn CLI, editors); tsc runs against the referenced configs.
	"compilerOptions": {
		"paths": {
			"@/*": ["./src/client/*"]
		}
	},
	"files": [],
	"references": [
		{ "path": "./tsconfig.app.json" },
		{ "path": "./tsconfig.worker.json" },
		{ "path": "./tsconfig.node.json" }
	]
}
