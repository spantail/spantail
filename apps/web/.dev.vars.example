# Copy to .dev.vars (gitignored) and fill in the values.

# Required. Signs session tokens; if it is missing or shorter than 32
# characters, auth/session requests fail closed (error out) rather than signing
# with a forgeable value. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Optional. The canonical origin for email links and OAuth callbacks. When
# unset, the app derives it from each incoming request — enough for local dev
# and for a deploy served from its own origin. Set it to pin a canonical origin
# behind a custom domain or a proxy that rewrites the host.
BETTER_AUTH_URL=http://localhost:5173

# Social login (optional). Set a provider's client id + secret to let an
# instance admin enable it under Settings > Social login. Leave blank to keep
# the provider unavailable. Register the callback URL with the provider as
# ${BETTER_AUTH_URL}/api/auth/callback/google and .../callback/github.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
