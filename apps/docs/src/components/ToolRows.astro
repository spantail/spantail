---
// Home "Tools & automation" row: three horizontal cards (CLI, MCP, Claude
// Plugin), each a chip icon + title + description + trailing arrow. Icons are
// inlined here (terminal / MCP / Claude aren't all in Starlight's icon set and
// the icon picks by `id`); strings + per-locale hrefs come from index.mdx.
interface Item {
	id: "cli" | "mcp" | "claude";
	title: string;
	body: string;
	href: string;
}

const { items } = Astro.props as { items: Item[] };
---

<div class="tool-rows not-content">
	{
		items.map((it) => (
			<a class="tool-row" href={it.href}>
				<span class="chip">
					{it.id === "cli" && (
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
							<polyline points="4 17 10 11 4 5" />
							<line x1="12" y1="19" x2="20" y2="19" />
						</svg>
					)}
					{it.id === "mcp" && (
						<svg viewBox="13 12 170 180" fill="none" stroke="currentColor" stroke-width="12" stroke-linecap="round" stroke-linejoin="round">
							<path d="M25 97.853 92.882 29.971c9.373-9.373 24.569-9.373 33.941 0 9.373 9.372 9.373 24.568 0 33.941L75.558 115.177" />
							<path d="m76.265 114.47 50.558-50.558c9.372-9.373 24.568-9.373 33.941 0l.353.353c9.373 9.373 9.373 24.569 0 33.942L99.725 159.6c-3.125 3.124-3.125 8.189 0 11.313l12.606 12.607" />
							<path d="M109.853 46.941 59.648 97.146c-9.372 9.372-9.372 24.568 0 33.941 9.373 9.372 24.569 9.372 33.941 0l50.205-50.205" />
						</svg>
					)}
					{it.id === "claude" && (
						<svg viewBox="0 0 16 16" fill="currentColor">
							<path d="m3.127 10.604 3.135-1.76.053-.153-.053-.085H6.11l-.525-.032-1.791-.048-1.554-.065-1.505-.08-.38-.081L0 7.832l.036-.234.32-.214.455.04 1.009.069 1.513.105 1.097.064 1.626.17h.259l.036-.105-.089-.065-.068-.064-1.566-1.062-1.695-1.121-.887-.646-.48-.327-.243-.306-.104-.67.435-.48.585.04.15.04.593.456 1.267.981 1.654 1.218.242.202.097-.068.012-.049-.109-.181-.9-1.626-.96-1.655-.428-.686-.113-.411a2 2 0 0 1-.068-.484l.496-.674L4.446 0l.662.089.279.242.411.94.666 1.48 1.033 2.014.302.597.162.553.06.17h.105v-.097l.085-1.134.157-1.392.154-1.792.052-.504.25-.605.497-.327.387.186.319.456-.045.294-.19 1.23-.37 1.93-.243 1.29h.142l.161-.16.654-.868 1.097-1.372.484-.545.565-.601.363-.287h.686l.505.751-.226.775-.707.895-.585.759-.839 1.13-.524.904.048.072.125-.012 1.897-.403 1.024-.186 1.223-.21.553.258.06.263-.218.536-1.307.323-1.533.307-2.284.54-.028.02.032.04 1.029.098.44.024h1.077l2.005.15.525.346.315.424-.053.323-.807.411-3.631-.863-.872-.218h-.12v.073l.726.71 1.331 1.202 1.667 1.55.084.383-.214.302-.226-.032-1.464-1.101-.565-.497-1.28-1.077h-.084v.113l.295.432 1.557 2.34.08.718-.112.234-.404.141-.444-.08-.911-1.28-.94-1.44-.759-1.291-.093.053-.448 4.821-.21.246-.484.186-.403-.307-.214-.496.214-.98.258-1.28.21-1.016.19-1.263.112-.42-.008-.028-.092.012-.953 1.307-1.448 1.957-1.146 1.227-.274.109-.477-.247.045-.44.266-.39 1.586-2.018.956-1.25.617-.723-.004-.105h-.036l-4.212 2.736-.75.096-.324-.302.04-.496.154-.162 1.267-.871z" />
						</svg>
					)}
				</span>
				<div class="tx">
					<h4>{it.title}</h4>
					<p>{it.body}</p>
				</div>
				<span class="go">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
						<line x1="5" y1="12" x2="19" y2="12" />
						<polyline points="12 5 19 12 12 19" />
					</svg>
				</span>
			</a>
		))
	}
</div>

<style>
	.tool-rows {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 16px;
		margin: 1.5rem 0;
	}
	.tool-row {
		display: flex;
		align-items: center;
		gap: 16px;
		border: 1px solid var(--sp-border);
		border-radius: 13px;
		padding: 18px 22px;
		background: var(--sp-card);
		text-decoration: none;
		color: inherit;
		transition:
			border-color 0.15s ease,
			background 0.15s ease;
	}
	.tool-row:hover {
		border-color: var(--sp-border-strong);
		background: var(--sp-subtle);
	}
	.chip {
		width: 38px;
		height: 38px;
		border-radius: 10px;
		display: grid;
		place-items: center;
		background: var(--sp-subtle-2);
		border: 1px solid var(--sp-border);
		flex: 0 0 auto;
	}
	.chip svg {
		width: 19px;
		height: 19px;
		color: var(--sp-fg-soft);
	}
	.tx {
		flex: 1;
		min-width: 0;
	}
	.tx h4 {
		margin: 0 0 3px;
		font-size: 16px;
		font-weight: 600;
		letter-spacing: -0.01em;
		color: var(--sp-fg);
	}
	.tx p {
		margin: 0;
		font-size: 13.5px;
		color: var(--sp-muted);
	}
	.go {
		display: grid;
		place-items: center;
		color: var(--sp-faint);
		flex: 0 0 auto;
	}
	.tool-row:hover .go {
		color: var(--sp-fg);
	}
	.go svg {
		width: 18px;
		height: 18px;
	}
	@media (max-width: 50rem) {
		.tool-rows {
			grid-template-columns: 1fr;
		}
	}
</style>
