---
// Home "Choose your path" grid: 2×2 cards, each a chip icon + title +
// description + a "more →" affordance. The whole card is the link. Strings
// (and per-locale hrefs) come from the page's index.mdx so they stay in the
// existing i18n source; only the layout/icons live here.
import { Icon } from "@astrojs/starlight/components";
import type { StarlightIcon } from "@astrojs/starlight/types";

interface Item {
	icon: StarlightIcon;
	title: string;
	body: string;
	href: string;
	more: string;
}

const { items } = Astro.props as { items: Item[] };
---

<div class="path-cards not-content">
	{
		items.map((it) => (
			<a class="path-card" href={it.href}>
				<div class="head">
					<span class="chip">
						<Icon name={it.icon} />
					</span>
					<h3>{it.title}</h3>
				</div>
				<p>{it.body}</p>
				<span class="more">
					{it.more}
					<Icon name="right-arrow" />
				</span>
			</a>
		))
	}
</div>

<style>
	.path-cards {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 18px;
		margin: 1.5rem 0;
	}
	.path-card {
		display: flex;
		flex-direction: column;
		border: 1px solid var(--sp-border);
		border-radius: 14px;
		padding: 24px;
		background: var(--sp-card);
		text-decoration: none;
		color: inherit;
		transition:
			border-color 0.15s ease,
			background 0.15s ease;
	}
	.path-card:hover {
		border-color: var(--sp-border-strong);
	}
	.head {
		display: flex;
		align-items: center;
		gap: 13px;
		margin-bottom: 14px;
	}
	.chip {
		width: 38px;
		height: 38px;
		border-radius: 10px;
		display: grid;
		place-items: center;
		background: var(--sp-subtle-2);
		border: 1px solid var(--sp-border);
		flex: 0 0 auto;
	}
	.chip :global(svg) {
		width: 19px;
		height: 19px;
		color: var(--sp-fg-soft);
	}
	h3 {
		font-size: 18px;
		font-weight: 650;
		letter-spacing: -0.01em;
		margin: 0;
		color: var(--sp-fg);
	}
	p {
		margin: 0;
		color: var(--sp-muted);
		font-size: 14.5px;
		line-height: 1.55;
	}
	.more {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		margin-top: 14px;
		font-size: 14px;
		font-weight: 550;
		color: var(--sp-fg);
	}
	.more :global(svg) {
		width: 15px;
		height: 15px;
	}
	@media (max-width: 50rem) {
		.path-cards {
			grid-template-columns: 1fr;
		}
	}
</style>
