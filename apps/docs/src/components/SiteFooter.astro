---
// Home page footer: the Spantail brand mark + a copyright line. Matches the
// mockup's `.site-footer` (brand left, copyright right). The copyright text is
// passed in so each locale's index.mdx owns its string.
import mark from "../assets/spantail-mark.svg";

interface Props {
	copyright: string;
}

const { copyright } = Astro.props as Props;
---

<footer class="site-footer not-content">
	<div class="ft-brand">
		<img class="ft-mark" src={mark.src} alt="" />
		Spantail
	</div>
	<div class="copyright">{copyright}</div>
</footer>

<style>
	.site-footer {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		margin-top: 80px;
		padding: 32px 0 4px;
		border-top: 1px solid var(--sp-border);
	}
	.ft-brand {
		display: flex;
		align-items: center;
		gap: 9px;
		font-size: 14px;
		font-weight: 600;
		color: var(--sp-fg);
	}
	.ft-mark {
		width: 22px;
		height: 22px;
		object-fit: contain;
	}
	.copyright {
		font-family: var(--font-mono);
		font-size: 13px;
		font-weight: 500;
		color: var(--sp-muted);
	}
</style>
