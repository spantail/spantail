{
	"name": "spantail",
	"version": "0.1.0",
	"description": "Command-line client for Spantail, the open-source work logging and reporting platform: log work, list entries, run reports, and serve a stdio MCP server.",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spantail/spantail.git",
		"directory": "packages/cli"
	},
	"homepage": "https://github.com/spantail/spantail#readme",
	"bugs": "https://github.com/spantail/spantail/issues",
	"keywords": [
		"time-tracking",
		"work-log",
		"timesheet",
		"reporting",
		"cli",
		"mcp"
	],
	"engines": {
		"node": ">=24"
	},
	"bin": {
		"spantail": "./dist/index.mjs"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"prepack": "tsdown",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@spantail/core": "workspace:*",
		"@spantail/sdk": "workspace:*",
		"@types/node": "^25.9.3",
		"tsdown": "^0.22.2",
		"vitest": "^4.1.8"
	}
}
